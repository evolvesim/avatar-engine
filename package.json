{
  "name": "@evolvesim/avatar-engine",
  "version": "0.3.17",
  "description": "Shared real-time 3D avatar engine for Evolve Simulations products \u2014 emotion state machine, Virtual Director, viseme lip-sync, skeletal animation, procedural micro-animations",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@react-three/fiber": "^8.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/three": "^0.165.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "three": "^0.160.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "avatar",
    "3d",
    "lip-sync",
    "viseme",
    "arkit",
    "emotion",
    "virtual-director",
    "three.js",
    "react-three-fiber",
    "azure-tts",
    "elevenlabs",
    "mascotbot"
  ]
}